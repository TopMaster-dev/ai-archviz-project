# ============================================================================
#  Arise (ai-archviz-pro) 環境変数テンプレート
#  このファイルをコピーして `.env.local` を作成し、各値を設定してください。
#  `.env.local` は .gitignore 済み（コミットしないこと）。
# ============================================================================

# --- Google Gemini -----------------------------------------------------------
# フェーズ1ではテスト期間中のフォールバック/開発用キー。
# 本番のテストユーザーは BYOK（各自のキーをアプリ画面で保存）を使用するため、
# このサーバーキーは管理者デバッグ用途に限定する。
GEMINI_API_KEY=
# テキスト生成（配置説明・AIエージェント相談）に使う Flash 系モデルの上書き（任意）
# 既定: gemini-2.5-flash（旧 gemini-2.0-flash は提供終了のため変更）
GEMINI_PLACEMENT_CAPTION_MODEL=gemini-2.5-flash

# --- Cloudinary（素材・家具カタログ・サムネイル保管）------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Supabase（認証 + Postgres + ストレージ）--------------------------------
# フロントエンド公開用（anon key は RLS 前提で公開可）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# サーバーレス関数（api/*）専用。絶対にクライアントへ露出しないこと。
SUPABASE_SERVICE_ROLE_KEY=
# BYOK キー暗号化に使う 32 バイトのシークレット（pgsodium/アプリ層暗号で使用）
BYOK_ENCRYPTION_KEY=
