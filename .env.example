# ============================================================================
#  Arise (ai-archviz-pro) 環境変数テンプレート
#  このファイルをコピーして `.env.local` を作成し、各値を設定してください。
#  `.env.local` は .gitignore 済み（コミットしないこと）。
# ============================================================================

# --- Google Gemini -----------------------------------------------------------
# フェーズ1ではテスト期間中のフォールバック/開発用キー。
# 本番のテストユーザーは BYOK（各自のキーをアプリ画面で保存）を使用するため、
# このサーバーキーは管理者デバッグ用途に限定する。
GEMINI_API_KEY=
# AIモデルの使い分け（タスク別・すべて任意。未設定なら既定値を使用）。
# 画像生成・編集（AIレンダリング/AI画像編集）。既定: gemini-3-pro-image-preview（GAモデルへ固定したい場合はここで上書き）
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
# 配置説明キャプション（軽量）。既定: gemini-2.5-flash（旧 gemini-2.0-flash は提供終了のため変更）
GEMINI_PLACEMENT_CAPTION_MODEL=gemini-2.5-flash
# AIエージェント相談チャット。未設定ならキャプションと同じモデル。回答品質を上げたい場合のみ上位モデルへ独立に差し替え
GEMINI_AGENT_MODEL=

# --- 消しゴムAI / 決定論合成（エリア編集 フェーズ1・2）--------------------------
# エリア編集の「削除／参照商品の配置」を、Gemini とは別の専用AI（Replicate）で処理する。
# すべてアプリ保有の共通キーで呼ぶ（ユーザーのキー設定は不要）。未設定/失敗時は自動で従来 Gemini へフォールバック。
# ※ VITE_ 接頭辞のフラグはビルド時に取り込まれるため、値を変えたら必ず「再デプロイ」すること（env 変更だけでは反映されない）。
# 詳しい有効化手順・QAチェックリストは docs/消しゴム・合成AI_有効化とQA手順.md を参照。
#
# 共通キー（Replicate）。消しゴム・合成・リライトすべてで使用。未設定なら各機能は Gemini フォールバック。
REPLICATE_API_TOKEN=
# 候補エンジン Bria のキー（任意）。Replicate と実機比較する用。未設定なら Bria は使われない。
# 使うには下の INPAINT_*_ENGINE で bria を選ぶ（例: INPAINT_REMOVE_ENGINE=bria:eraser）。Bria も有料サービス。
BRIA_API_TOKEN=
# 消しゴムAI（削除／マスク内生成）を有効化。既定 OFF（'true' 以外は無効）。要 REPLICATE_API_TOKEN。
VITE_ENABLE_INPAINT=false
# 参照商品の決定論合成（切り抜き→配置）を有効化。既定 OFF。要 REPLICATE_API_TOKEN。消しゴムとは独立に切替可。
VITE_ENABLE_COMPOSITE=false
# 合成後のAIリライト（照明なじませ・IC-Light）。既定 OFF・未検証。有効化前に必ず実機で出力を確認すること。
VITE_ENABLE_RELIGHT=false
# 使用エンジンの差し替え（任意・通常は未設定＝既定エンジン）。値は登録済みエンジンID。
#   INPAINT_REMOVE_ENGINE   既定 replicate:remove-object       (zylim0702/remove-object) / 候補 bria:eraser
#   INPAINT_GENERATE_ENGINE 既定 replicate:flux-fill-pro       (black-forest-labs/flux-fill-pro)
#   INPAINT_CUTOUT_ENGINE   既定 replicate:background-remover  (851-labs/background-remover) / 候補 bria:remove-background
#   INPAINT_RELIGHT_ENGINE  既定 replicate:ic-light-background (zsxkib/ic-light-background)
#   ※ bria:* を選ぶ場合は BRIA_API_TOKEN が必要。
INPAINT_REMOVE_ENGINE=
INPAINT_GENERATE_ENGINE=
INPAINT_CUTOUT_ENGINE=
INPAINT_RELIGHT_ENGINE=

# --- 運営管理ダッシュボード（?admin・フェーズ1/2）-----------------------------
# 管理画面（AIキー状態・AI利用/費用・インフラ状況）を開けるログインメールの許可リスト（カンマ区切り）。
# 未設定なら全員 deny（管理画面は「アクセス権なし」）。運営自身のログインメールを設定する。
ADMIN_EMAILS=
# Vercel の最新デプロイ状態パネル用（任意）。未設定ならインフラパネルはリンク代替表示になる。
VERCEL_TOKEN=
VERCEL_PROJECT_ID=

# --- Cloudinary（素材・家具カタログ・サムネイル保管）------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Supabase（認証 + Postgres + ストレージ）--------------------------------
# フロントエンド公開用（anon key は RLS 前提で公開可）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# サーバーレス関数（api/*）専用。絶対にクライアントへ露出しないこと。
SUPABASE_SERVICE_ROLE_KEY=
# BYOK キー暗号化に使う 32 バイトのシークレット（pgsodium/アプリ層暗号で使用）
BYOK_ENCRYPTION_KEY=

# --- DB バックアップ（管理表 row 29／scripts/db-backup.sh・任意）---------------
# 日次 pg_dump 用の接続文字列。アプリ実行時には不要。GitHub Actions では同名の
# リポジトリ Secret に登録する（ローカル手動実行時のみ .env.local 等で使用）。
# 必ず Session pooler(:5432) か Direct connection を使うこと（Transaction pooler :6543 は pg_dump 非対応）。
# 例: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# --- 事前削除通知メール（row 106）＋ Cron -----------------------------------
# 自動失効データの物理削除前に、所有者へ SMTP で警告メールを送る（api/cron/purge-warning, 日次）。
# Vercel Cron（vercel.json）から起動し、CRON_SECRET で保護する。CRON_SECRET 設定時、Vercel Cron は
# Authorization: Bearer <CRON_SECRET> を自動付与する（外部スケジューラからも同ヘッダで起動可）。
CRON_SECRET=
# SMTP 送信元サーバ。SMTP_SECURE は 465=true / 587(STARTTLS)=false。
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- 広告（Google AdSense・仮 260624）---------------------------------------
# AIレンダリング/生成オーバーレイ中に表示する広告枠（components/AdSlot.tsx）。
# 未設定の間は「広告スペース（Google AdSense・仮）」のプレースホルダを表示する。
# AdSense アカウント取得後、公開者ID（ca-pub-…）と各広告ユニットのスロットIDを設定すると実広告に切替わる。
# ※AdSense ポリシー上、オーバーレイ/ポップアップ上の広告には制限がある場合がある。本番公開前に要確認。
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT_1=
VITE_ADSENSE_SLOT_2=
VITE_ADSENSE_SLOT_3=

# --- 自動アカウントロック（row 54）---------------------------------------------
# 同一PC＋同一回線（IP＋端末FP=UA+画面）から短時間に複数アカウントが作られた場合に自動ロックする。
# テスト期は共有Wi-Fiで誤検知しやすいため既定 OFF（'true' 以外は無効）。本番開始時に true へ。
# 検知はログイン記録時（api/session-log）に評価。ロック解除は管理者が DB で locked_at=null に戻す。
ENABLE_AUTO_ACCOUNT_LOCK=false
AUTO_LOCK_THRESHOLD=3
AUTO_LOCK_WINDOW_HOURS=24
